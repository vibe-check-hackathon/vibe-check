# Documentation only — nothing in this repo auto-loads a .env file
# (zero-dependency policy, AGENTS.md §29: no dotenv package). This just
# lists every environment variable the app reads, so local setup and the
# Render dashboard (render.yaml prompts for the same list) stay in sync.
#
# Every one of these is OPTIONAL. Without any of them the app still runs —
# each missing key just turns off the feature it gates, reported honestly by
# GET /integrations, never a crash. See SECURITY.md for what's actually
# protected and what isn't yet.

# Postgres for accounts + sessions (laura/pipeline/lib/db.js) — the one real
# dependency in this repo (node-postgres/pg), added because file-based
# storage doesn't survive a restart. Free option: https://neon.tech (its free
# tier doesn't expire, unlike Render's own free Postgres, which is deleted
# after 30 days). Without this, falls back to accounts.json + in-memory
# sessions — same as before this existed, resets on restart.
DATABASE_URL=<postgresql://user:pass@host/dbname>

# LLM features (Checky, outbound scan, command-bar fallback). Set ONE.
ANTHROPIC_API_KEY=<set-by-secret-manager>
OPENAI_API_KEY=<set-by-secret-manager>

# ...or any OpenAI-compatible endpoint instead — including a free-tier hosted
# provider (e.g. Groq: https://api.groq.com/openai, model llama-3.3-70b-versatile),
# not just a local Ollama/LM Studio server. Same shape can also be set live
# from the Checky UI ("Use a free / self-hosted endpoint instead").
LLM_BASE_URL=<e.g. https://api.groq.com/openai>
LLM_API_KEY=<set-by-secret-manager>
LLM_MODEL=<e.g. llama-3.3-70b-versatile>

# Interview-invite email (laura/pipeline/lib/email.js), via Resend.
RESEND_API_KEY=<set-by-secret-manager>
RESEND_FROM=FirstCheck <onboarding@resend.dev>

# Live interview voice sessions (laura/pipeline/lib/interview-agent.js).
ELEVENLABS_API_KEY=<set-by-secret-manager>
ELEVENLABS_AGENT_ID=<set-by-secret-manager>

# Production server port (defaults to 8080 — see laura/pipeline/app-server.js).
# PORT=8080
